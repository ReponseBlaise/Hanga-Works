// ============================================================
// HANGA WORKS — Prisma Schema
// File: backend/prisma/schema.prisma
// Database: PostgreSQL
// ORM: Prisma
// Version: 1.0 — Phase 1
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  LEARNER
  EMPLOYER
  INSTITUTION
  MENTOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  HIRED
  REJECTED
}

enum JobType {
  FULL_TIME
  PART_TIME
  REMOTE
  HYBRID
  INTERNSHIP
  FREELANCE
}

enum OrgType {
  EMPLOYER
  INSTITUTION
}

// ============================================================
// USER & IDENTITY
// ============================================================

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?       @unique
  passwordHash String
  role         Role          @default(LEARNER)
  status       AccountStatus @default(ACTIVE)
  bio          String?
  avatarUrl    String?
  location     String?

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  skills         UserSkill[]
  enrollments    Enrollment[]
  certifications Certification[]
  applications   Application[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// ORGANIZATION
// ============================================================

model Organization {
  id      String  @id @default(uuid())
  name    String
  type    OrgType
  website String?

  // Relations
  users          User[]
  courses        Course[]
  jobs           Job[]
  certifications Certification[]

  createdAt DateTime @default(now())
}

// ============================================================
// SKILLS
// ============================================================

model Skill {
  id   String  @id @default(uuid())
  name String  @unique
  tag  String?

  // Relations
  userSkills   UserSkill[]
  jobSkills    JobSkill[]
  courseSkills CourseSkill[]
}

model UserSkill {
  id      String           @id @default(uuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill            @relation(fields: [skillId], references: [id])
  level   ProficiencyLevel @default(BEGINNER)
  verified Boolean         @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, skillId])
}

// ============================================================
// LEARNING MANAGEMENT SYSTEM
// ============================================================

model Course {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String
  published   Boolean @default(false)
  thumbnailUrl String?

  // Relations
  institutionId  String?
  institution    Organization?   @relation(fields: [institutionId], references: [id])
  modules        CourseModule[]
  enrollments    Enrollment[]
  certifications Certification[]
  skills         CourseSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model CourseModule {
  id       String  @id @default(uuid())
  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  content  String?
  videoUrl String?
  order    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model Enrollment {
  id       String           @id @default(uuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course           @relation(fields: [courseId], references: [id])
  progress Int              @default(0)
  status   EnrollmentStatus @default(ENROLLED)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([status])
}

// ============================================================
// CERTIFICATION
// ============================================================

model Certification {
  id       String  @id @default(uuid())
  code     String  @unique @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id])
  issuerId String?
  issuer   Organization? @relation(fields: [issuerId], references: [id])
  pdfUrl   String?

  issuedAt  DateTime  @default(now())
  expiresAt DateTime?

  @@unique([userId, courseId])
  @@index([code])
}

// ============================================================
// JOB MARKETPLACE
// ============================================================

model Job {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String
  location    String?
  jobType     JobType @default(FULL_TIME)
  salaryMin   Int?
  salaryMax   Int?
  isActive    Boolean @default(true)

  // Relations
  employerId   String
  employer     Organization  @relation(fields: [employerId], references: [id])
  skills       JobSkill[]
  applications Application[]

  postedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?

  @@index([isActive])
  @@index([employerId])
}

model JobSkill {
  id      String @id @default(uuid())
  jobId   String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@unique([jobId, skillId])
}

model CourseSkill {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id])

  @@unique([courseId, skillId])
}

model Application {
  id     String            @id @default(uuid())
  userId String
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job               @relation(fields: [jobId], references: [id])
  status ApplicationStatus @default(APPLIED)

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id      String  @id @default(uuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String
  payload String?
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id      String  @id @default(uuid())
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])
  action  String
  meta    String?

  createdAt DateTime @default(now())

  @@index([actorId])
}
