# Copy to .env and nn a valid Postgres DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/sewi_d?schema=public"

# S3 / Cloudflare R2
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # omit for AWS S3
S3_BUCKET=hanga-certs
S3_ACCESS_KEY_ID=your-key
S3_SECRET_ACCESS_KEY=your-secret
S3_REGION=auto            # use "auto" for R2, e.g. "us-east-1" for AWS
S3_PUBLIC_URL=https://pub-xxx.r2.dev  # public bucket base URL

APP_URL=http://localhost:3000  # used inside the PDF as the verify link
