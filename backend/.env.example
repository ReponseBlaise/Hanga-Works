# Copy to .env and set a valid Postgres DATABASE_URL
DATABASE_URL=

JWT_SECRET=
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3000

# Email (Gmail via Nodemailer)
EMAIL_USER=
EMAIL_FROM=
APP_PASSWORD=

# SendGrid (optional alternative)
SENDGRID_API_KEY=

# Cloudinary — profile avatars + course images/videos/documents
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: root folder in Cloudinary (default hanga-works)
CLOUDINARY_FOLDER=hanga-works
# Optional: unsigned upload preset from Cloudinary dashboard
CLOUDINARY_UPLOAD_PRESET=

# S3 / R2 — certificate PDFs + fallback presigned course uploads
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_ENDPOINT=

# Flutterwave — premium course payments
FLUTTERWAVE_SECRET_KEY=
